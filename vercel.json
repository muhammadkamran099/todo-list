{
  "version": 2,
  "builds": [
    {
      "src": "todo/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb",
        "runtime": "python3.12"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "todo/wsgi.py"
    }
  ],
  "buildCommand": "bash build_files.sh"
}
